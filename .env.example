# copy to .env and fill in. .env is gitignored.
OPENAI_API_KEY=sk-...
# AGENT_MODEL=gpt-5.5
# AGENT_PROXY=http://127.0.0.1:7890   # set to "none" to connect directly
# MOONSHOT_API_KEY=sk-...             # use Kimi instead of OpenAI
# SHOW_SLICE=1                        # print the slice each turn

# --- memory tier (optional plug: install memem, then point at a vault) ---
# MEMEM_VAULT=~/obsidian-brain        # memem's lesson vault (markdown)
# MEMEM_DIR=~/.memem                  # memem's index/state dir
# (with memem installed + a vault, the slice gains a RELEVANT MEMORY tier; else NullMemory)

# --- safety / hooks (optional) ---
# AGENT_POLICY=guard                      # guard (default, blocks catastrophic cmds) | readonly | allow
# AGENT_VERIFY_CMD=python3 -m pytest -q   # Oracle: run before "done"; failures force another turn
# AGENT_MAX_TOKENS=200000                 # budget ceiling
